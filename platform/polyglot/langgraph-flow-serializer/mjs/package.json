{
  "name": "@internal/langgraph-flow-serializer",
  "version": "1.0.0",
  "description": "Polyglot serializer for LangChain/LangGraph flow graphs",
  "type": "module",
  "private": true,
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./adapters": "./src/adapters/index.ts",
    "./exporters": "./src/exporters/mermaid.exporter.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build": "echo 'No build step'"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "vitest": "^3.2.0",
    "typescript": "~5.9.3",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
