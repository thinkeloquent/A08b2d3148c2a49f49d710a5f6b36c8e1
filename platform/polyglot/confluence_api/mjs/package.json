{
  "name": "@mta/confluence-api",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    ".": "./src/index.mjs",
    "./client": "./src/client/ConfluenceFetchClient.mjs",
    "./models": "./src/models/index.mjs",
    "./services": "./src/services/index.mjs",
    "./server": "./src/server/index.mjs",
    "./sdk": "./src/sdk/client.mjs",
    "./logger": "./src/logger.mjs"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "start:server": "node src/server/index.mjs"
  },
  "dependencies": {
    "@internal/env-resolver": "workspace:*",
    "fastify": "^4.28.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.1.0",
    "undici": "^6.21.0",
    "zod": "^3.23.8",
    "commander": "^11.1.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0",
    "vitest": "^2.1.0",
    "@biomejs/biome": "^1.9.0"
  }
}
