{
  "name": "@internal/common-exceptions",
  "version": "1.0.0",
  "description": "Standardized exception handling for Fastify with cross-framework parity",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./fastify": {
      "types": "./dist/fastify/index.d.ts",
      "import": "./dist/fastify/index.js"
    },
    "./undici": {
      "types": "./dist/undici/index.d.ts",
      "import": "./dist/undici/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "biome lint src",
    "format": "prettier --write src",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "fastify",
    "exceptions",
    "error-handling",
    "http",
    "api",
    "undici"
  ],
  "author": "Architecture Team",
  "license": "MIT",
  "dependencies": {
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "fastify": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "fastify": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "fastify": "^4.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "schemas"
  ]
}
