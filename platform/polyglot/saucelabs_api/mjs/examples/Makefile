# =============================================================================
# Makefile — Sauce Labs API SDK Examples (Node.js / MJS)
#
# Targets for running the example scripts.
# Examples use the parent package directly (no separate install needed).
# =============================================================================

.PHONY: install start dev

# -----------------------------------------------------------------------------
# install — No-op; examples import from the parent package via relative paths.
# -----------------------------------------------------------------------------
install:
	@echo "No install required. Examples use the parent package at ../src/index.mjs"

# -----------------------------------------------------------------------------
# start — Run the basic-usage example script.
# -----------------------------------------------------------------------------
start:
	node basic-usage.mjs

# -----------------------------------------------------------------------------
# dev — Run the Fastify demo server for interactive exploration.
# -----------------------------------------------------------------------------
dev:
	node fastify-app/server.mjs
