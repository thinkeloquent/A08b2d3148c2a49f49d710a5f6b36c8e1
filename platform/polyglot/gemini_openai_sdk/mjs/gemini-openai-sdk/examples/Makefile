# =============================================================================
# Gemini OpenAI SDK - Node.js Examples Makefile
# =============================================================================

.PHONY: install start dev help

# Install dependencies
install:
	cd .. && npm install

# Run basic usage examples
start:
	node basic-usage.mjs

# Run Fastify development server
dev:
	node fastify-app.mjs

# Show help
help:
	@echo "Gemini OpenAI SDK - Node.js Examples"
	@echo ""
	@echo "Usage: make [target]"
	@echo ""
	@echo "Targets:"
	@echo "  install    Install package dependencies"
	@echo "  start      Run basic usage examples"
	@echo "  dev        Run Fastify server"
	@echo "  help       Show this help message"
