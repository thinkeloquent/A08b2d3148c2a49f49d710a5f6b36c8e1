{
  "name": "static-app-loader",
  "version": "1.0.0",
  "description": "Polyglot static app loader for Fastify with SPA routing, template engines, and multi-app support",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "@fastify/view": "^10.0.0",
    "fastify-plugin": "^5.0.0",
    "zod": "^3.23.0",
    "mustache": "^4.2.0",
    "liquidjs": "^10.0.0",
    "edge.js": "^6.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/mustache": "^4.2.0",
    "@types/node": "^20.0.0",
    "fastify": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "fastify": ">=4.0.0"
  },
  "keywords": [
    "fastify",
    "static",
    "spa",
    "plugin",
    "polyglot"
  ],
  "license": "MIT"
}
