# Docker Compose Makefile for mta-v800
# Manages postgres, redis, and elasticsearch services defined in docker-compose.yml
# Usage: make -f Makefile.docker-compose [target]
# Default: help

# === Get Makefile Directory (Project Root) ===
MAKEFILE_DIR := $(dir $(abspath $(lastword $(MAKEFILE_LIST))))

# === Configuration Variables ===
PROJECT_NAME ?= mta-v800
COMPOSE_FILE := $(MAKEFILE_DIR)docker-compose.yml
COMPOSE_PROJECT := mta

# Docker Compose command
COMPOSE := docker compose -f $(COMPOSE_FILE) -p $(COMPOSE_PROJECT)

# Service names (must match docker-compose.yml)
SVC_POSTGRES := postgres
SVC_REDIS := redis
SVC_ELASTICSEARCH := elasticsearch

# Connection defaults (must match docker-compose.yml)
POSTGRES_PORT ?= 53100
POSTGRES_USER ?= postgres
POSTGRES_PASSWORD ?= postgres
POSTGRES_DB ?= mta_dev
REDIS_PORT ?= 53200
ELASTICSEARCH_PORT ?= 53300

# CI settings
HEALTH_TIMEOUT ?= 60
HEALTH_INTERVAL ?= 2

# Colors for output
RED := \033[0;31m
GREEN := \033[0;32m
YELLOW := \033[1;33m
BLUE := \033[0;34m
PURPLE := \033[0;35m
CYAN := \033[0;36m
WHITE := \033[1;37m
NC := \033[0m

# === Default Target ===
.DEFAULT_GOAL := help

