	@echo "  $(GREEN)restart-postgres$(NC)     Restart postgres"
	@echo "  $(GREEN)restart-redis$(NC)        Restart redis"
	@echo "  $(GREEN)restart-elasticsearch$(NC) Restart elasticsearch"
	@echo ""
	@echo "$(YELLOW)Status & Logs:$(NC)"
	@echo "  $(GREEN)ps$(NC)                   List running services"
	@echo "  $(GREEN)status$(NC)               Show detailed service status"
	@echo "  $(GREEN)logs$(NC)                 Tail logs from all services"
	@echo "  $(GREEN)logs-postgres$(NC)        Tail postgres logs"
	@echo "  $(GREEN)logs-redis$(NC)           Tail redis logs"
	@echo "  $(GREEN)logs-elasticsearch$(NC)  Tail elasticsearch logs"
	@echo ""
	@echo "$(YELLOW)Health & Connectivity:$(NC)"
	@echo "  $(GREEN)health$(NC)               Check health of all services"
	@echo "  $(GREEN)wait$(NC)                 Block until all services are healthy"
	@echo "  $(GREEN)ping-postgres$(NC)        Test postgres connection"
	@echo "  $(GREEN)ping-redis$(NC)           Test redis connection"
	@echo "  $(GREEN)ping-elasticsearch$(NC)  Test elasticsearch connection"
