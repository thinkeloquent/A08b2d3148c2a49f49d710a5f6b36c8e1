{
  "name": "mta-v800",
  "version": "0.1.0",
  "description": "Multi-language monorepo (Python + JavaScript) using Nx",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "workspaces": [
    "packages_mjs/*",
    "platform-core/fastify",
    "fastify_apps/*",
    "fastify_server",
    "frontend_apps/*",
    "polyglot/*/mjs",
    "polyglot/gemini_openai_sdk/mjs/gemini-openai-sdk",
    "tools/package_mjs/cli-dev-runner",
    "frontend-components/*"
  ],
  "scripts": {
    "build": "pnpm nx run-many --verbose --target=build --output-style=stream",
    "build:log": "make build",
    "dev": "make dev-fastify",
    "test": "nx run-many -t test",
    "test:log": "mkdir -p logs && pnpm nx run-many --skip-nx-cache --verbose --target=test --output-style=stream 2>&1 | tee logs/pnpm-test-error.log && python3 .bin/parse_pnpm_build_errors.py",
    "clean": "nx run-many -t clean",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "graph": "nx graph",
    "affected": "nx affected",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "polynx": "node packages_mjs/project-generator/dist/index.js",
    "new": "node packages_mjs/project-generator/dist/index.js create",
    "dev:cli": "tsx tools/package_mjs/cli-dev-runner/src/index.ts"
  },
  "keywords": [
    "monorepo",
    "workspaces",
    "frontend",
    "fastapi",
    "fastify",
    "multi-language",
    "nx"
  ],
  "author": "",
