{
  "name": "@internal/cli-progressor",
  "version": "1.0.0",
  "private": true,
  "description": "CLI progress bars with Strategy, Builder, Observer, and State Machine patterns",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "progress",
    "progress-bar",
    "spinner"
  ],
  "author": "MTA",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
