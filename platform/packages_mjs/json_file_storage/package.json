{
  "name": "json_file_storage",
  "version": "1.0.0",
  "description": "File-based JSON storage with hash-based filenames",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "node --test",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "json",
    "storage",
    "file-storage",
    "cache",
    "hash",
    "typescript"
  ],
  "author": "json_file_storage contributors",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
