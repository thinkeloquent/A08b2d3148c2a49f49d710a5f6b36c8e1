{
  "name": "fetch-undici-gemini-openai-protocols",
  "version": "1.0.0",
  "description": "Protocol translation layer between OpenAI and Gemini API formats - extends fetch-undici",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./messages": {
      "import": "./dist/messages.js",
      "types": "./dist/messages.d.ts"
    },
    "./tools": {
      "import": "./dist/tools.js",
      "types": "./dist/tools.d.ts"
    },
    "./response": {
      "import": "./dist/response.js",
      "types": "./dist/response.d.ts"
    },
    "./streaming": {
      "import": "./dist/streaming.js",
      "types": "./dist/streaming.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openai",
    "gemini",
    "protocol",
    "translation",
    "llm",
    "api",
    "polyglot",
    "bridge"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "fetch-undici": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "fetch-undici": "^1.0.0"
  }
}
