{
  "name": "@internal/github-api-sdk-cli",
  "version": "1.0.0",
  "private": true,
  "description": "Shared GitHub API client, CLI prompts, config, and utilities for analysis tools",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "github",
    "api",
    "sdk",
    "cli",
    "analysis"
  ],
  "author": "MTA",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@internal/api-rate-limiter": "file:../api-rate-limiter-main",
    "@internal/env-resolver": "workspace:*",
    "@clack/prompts": "^0.9.1",
    "commander": "^12.1.0",
    "chalk": "^5.4.1",
    "octokit": "^4.1.2",
    "zod": "^3.24.4",
    "expect": "^29.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
